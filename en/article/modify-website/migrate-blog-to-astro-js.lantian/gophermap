i## The Island Feature		{{server_addr}}	{{server_port}}
iThe major feature of Astro.js, Island, can generate isolated areas in		{{server_addr}}	{{server_port}}
ithe page for each `.astro` file. These isolations include:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i- CSS isolation. Let's assume we have the following HTML/CSS code in `src/components/a.astro` :		{{server_addr}}	{{server_port}}
i  <p class="my-class">Hello World</p>		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i  <style>		{{server_addr}}	{{server_port}}
i    .my-class {		{{server_addr}}	{{server_port}}
i      font-size: 100px;		{{server_addr}}	{{server_port}}
i    }		{{server_addr}}	{{server_port}}
i  </style>		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iAstro.js will process the HTML and CSS, and add a tag starting with `data-astro-cid` :		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  <p class="my-class" data-astro-cid-123456>Hello World</p>		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i  <style>		{{server_addr}}	{{server_port}}
i    .my-class[data-astro-cid-123456] {		{{server_addr}}	{{server_port}}
i      font-size: 100px;		{{server_addr}}	{{server_port}}
i    }		{{server_addr}}	{{server_port}}
i  </style>		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iNow the CSS only applies to the `p` tag above.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iThe `data-astro-cid` tag is the same for all HTML/CSS originating from `src/components/a.astro` ,		{{server_addr}}	{{server_port}}
iso all CSS here will apply to all HTML from `a.astro` . But assume I		{{server_addr}}	{{server_port}}
ihave another component `src/components/b.astro` . It will get a		{{server_addr}}	{{server_port}}
idifferent tag, for example `data-astro-cid-654321` . Now the CSS from `a.astro`		{{server_addr}}	{{server_port}}
iwill not apply to `b.astro` .		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iThis is a handy feature while writing CSS, since you no longer worry		{{server_addr}}	{{server_port}}
iabout changing appearance of rest of the site while adjusting CSS for		{{server_addr}}	{{server_port}}
ia specific part of the page.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i- Javascript Component Isolation		{{server_addr}}	{{server_port}}
iSuppose I have Javascript code in my Astro template:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  ---		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i  ---		{{server_addr}}	{{server_port}}
i  <div id="test">Hello world</div>		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i  <script>		{{server_addr}}	{{server_port}}
i  document.getElementById("test").innerHTML = "Hi there";		{{server_addr}}	{{server_port}}
i  </script>		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iAstro.js will automatically generate an Island for this component, and		{{server_addr}}	{{server_port}}
ionly run the Javascript of this Island after page load is complete.		{{server_addr}}	{{server_port}}
iThis island is isolated from other parts of the web page, and will not		{{server_addr}}	{{server_port}}
islow down loading time for other parts.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iIn addition to improving page load speed, this also simplifies using `window.onload` .		{{server_addr}}	{{server_port}}
iThe old way of running a function after page is loaded is:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  window.onload = () => {		{{server_addr}}	{{server_port}}
i    console.log('Hello World')		{{server_addr}}	{{server_port}}
i  }		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iBut what if we have multiple functions to run? If we simply overwrite `window.onload` ,		{{server_addr}}	{{server_port}}
ithe previous function will never be executed:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  window.onload = () => {		{{server_addr}}	{{server_port}}
i    console.log('This function will never be executed')		{{server_addr}}	{{server_port}}
i  }		{{server_addr}}	{{server_port}}
i  window.onload = () => {		{{server_addr}}	{{server_port}}
i    console.log('Hello World')		{{server_addr}}	{{server_port}}
i  }		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iSo we need some more complex logic:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  function addLoadEvent(o) {		{{server_addr}}	{{server_port}}
i    // Store the previous window.onload		{{server_addr}}	{{server_port}}
i    var n = window.onload		{{server_addr}}	{{server_port}}
i    'function' != typeof window.onload		{{server_addr}}	{{server_port}}
i      ? (window.onload = o)		{{server_addr}}	{{server_port}}
i      : (window.onload = function () {		{{server_addr}}	{{server_port}}
i          // If window.onload was previously set, run that function as well		{{server_addr}}	{{server_port}}
i          n && n(), o()		{{server_addr}}	{{server_port}}
i        })		{{server_addr}}	{{server_port}}
i  }		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i  addLoadEvent(() => {		{{server_addr}}	{{server_port}}
i    console.log('This function is now executed')		{{server_addr}}	{{server_port}}
i  })		{{server_addr}}	{{server_port}}
i  addLoadEvent(() => {		{{server_addr}}	{{server_port}}
i    console.log('Hello World')		{{server_addr}}	{{server_port}}
i  })		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iIt works, but is a bit of hassle. With Astro.js, however, all the		{{server_addr}}	{{server_port}}
iabove are automated:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  ---		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i  ---		{{server_addr}}	{{server_port}}
i  <div id="test">Hello world</div>		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i  <script>		{{server_addr}}	{{server_port}}
i  // This code will be run after the entire page is loaded, with no additional config required		{{server_addr}}	{{server_port}}
i  document.getElementById("test").innerHTML = "Hi there";		{{server_addr}}	{{server_port}}
i  </script>		{{server_addr}}	{{server_port}}
