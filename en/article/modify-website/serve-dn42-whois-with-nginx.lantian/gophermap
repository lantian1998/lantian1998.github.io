i		{{server_addr}}	{{server_port}}
irewrite "^/([Rr][Ss])-(.+)$" /route-set/RS-$2 last;		{{server_addr}}	{{server_port}}
irewrite "^/([Aa][Ss])([0-9]+)-([Aa][Ss])([0-9]+)$" /as-block/$1$2-$3$4 last;		{{server_addr}}	{{server_port}}
rewrite "^/[Aa]		{{server_addr}}	{{server_port}}
