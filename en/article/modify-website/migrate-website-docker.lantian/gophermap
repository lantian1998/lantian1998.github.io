i        && ln -sf /dev/stderr /usr/local/nginx/logs/error.log		{{server_addr}}	{{server_port}}
i  EXPOSE 80 443		{{server_addr}}	{{server_port}}
i  ADD start.sh /start.sh		{{server_addr}}	{{server_port}}
