i  # Or set a default value:		{{server_addr}}	{{server_port}}
i  ARG THIS_ARCH=amd64		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iThen use it during build like this:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  docker build -t xddxdd/testimage --build-arg THIS_ARCH=amd64		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
