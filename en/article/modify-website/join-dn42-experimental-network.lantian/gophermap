i		{{server_addr}}	{{server_port}}
iFollow the		{{server_addr}}	{{server_port}}
iofficial guide		{{server_addr}}	{{server_port}}
ito create config files (replace placeholders with your AS/IPs). For		{{server_addr}}	{{server_port}}
