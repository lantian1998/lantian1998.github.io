i          cost 1;		{{server_addr}}	{{server_port}}
i          hello 2;		{{server_addr}}	{{server_port}}
i          retransmit 2;		{{server_addr}}	{{server_port}}
i          dead count 2;		{{server_addr}}	{{server_port}}
i          };		{{server_addr}}	{{server_port}}
