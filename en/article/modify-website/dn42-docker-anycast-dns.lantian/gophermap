i## Announcing IP from Containers		{{server_addr}}	{{server_port}}
iThe next step is installing Bird and announcing owned IPs. An example		{{server_addr}}	{{server_port}}
iof Dockerfile can be seen in		{{server_addr}}	{{server_port}}
ithis commit		{{server_addr}}	{{server_port}}
i. The changes are mostly relevant to installing Bird and Supervisord		{{server_addr}}	{{server_port}}
iand starting Bird and Dnsmasq with Supervisord. In addition, put a		{{server_addr}}	{{server_port}}
isimple Bird configuration to the container, so it will announce its		{{server_addr}}	{{server_port}}
iIPs via OSPF.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iNote that BGP isn't used, since an ASN needs to be manually allocated,		{{server_addr}}	{{server_port}}
iwhich in addition to complexity, may cause problems if they're		{{server_addr}}	{{server_port}}
iassigned incorrectly. But for OSPF, there is no unique identifiers for		{{server_addr}}	{{server_port}}
ieach device, so it's easier to deploy.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iThe configuration looks like: (Alpine uses Bird 2.0)		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  log syslog all;		{{server_addr}}	{{server_port}}
i  protocol device {}		{{server_addr}}	{{server_port}}
i  protocol ospf {		{{server_addr}}	{{server_port}}
i      ipv4 {		{{server_addr}}	{{server_port}}
i          import none;		{{server_addr}}	{{server_port}}
i          export all;		{{server_addr}}	{{server_port}}
i      };		{{server_addr}}	{{server_port}}
i      area 0.0.0.0 {		{{server_addr}}	{{server_port}}
i          interface "eth*" {		{{server_addr}}	{{server_port}}
i              type broadcast;		{{server_addr}}	{{server_port}}
i              cost 1;		{{server_addr}}	{{server_port}}
i              hello 2;		{{server_addr}}	{{server_port}}
i              retransmit 2;		{{server_addr}}	{{server_port}}
i              dead count 2;		{{server_addr}}	{{server_port}}
i          };		{{server_addr}}	{{server_port}}
i      };		{{server_addr}}	{{server_port}}
i  }		{{server_addr}}	{{server_port}}
i  protocol ospf v3 {		{{server_addr}}	{{server_port}}
i      ipv6 {		{{server_addr}}	{{server_port}}
i          import none;		{{server_addr}}	{{server_port}}
i          export all;		{{server_addr}}	{{server_port}}
i      };		{{server_addr}}	{{server_port}}
i      area 0.0.0.0 {		{{server_addr}}	{{server_port}}
i          interface "eth*" {		{{server_addr}}	{{server_port}}
i              type broadcast;		{{server_addr}}	{{server_port}}
i              cost 1;		{{server_addr}}	{{server_port}}
i              hello 2;		{{server_addr}}	{{server_port}}
i              retransmit 2;		{{server_addr}}	{{server_port}}
i              dead count 2;		{{server_addr}}	{{server_port}}
i          };		{{server_addr}}	{{server_port}}
i      };		{{server_addr}}	{{server_port}}
i  }		{{server_addr}}	{{server_port}}
