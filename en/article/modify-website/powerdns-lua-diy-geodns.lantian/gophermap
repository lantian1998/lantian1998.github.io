i  103.42.215.193		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i  # Los Angeles, USA		{{server_addr}}	{{server_port}}
i  $ dig +short lantian.pub		{{server_addr}}	{{server_port}}
i  185.186.147.110		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i  # France		{{server_addr}}	{{server_port}}
i  $ dig +short lantian.pub		{{server_addr}}	{{server_port}}
i  195.154.221.59		{{server_addr}}	{{server_port}}
