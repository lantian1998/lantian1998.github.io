i      if(!defined('__LANTIAN_REDIS_HOST__') || !defined('__LANTIAN_REDIS_PORT__')) return false;		{{server_addr}}	{{server_port}}
i      if(!class_exists('Redis')) return false;		{{server_addr}}	{{server_port}}
