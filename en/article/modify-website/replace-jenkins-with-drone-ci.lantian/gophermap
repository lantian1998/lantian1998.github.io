i      - |		{{server_addr}}	{{server_port}}
i        cat <<EOF >/root/.ssh/config		{{server_addr}}	{{server_port}}
i        StrictHostKeyChecking no		{{server_addr}}	{{server_port}}
i        UserKnownHostsFile=/dev/null		{{server_addr}}	{{server_port}}
i        VerifyHostKeyDNS yes		{{server_addr}}	{{server_port}}
i        LogLevel ERROR		{{server_addr}}	{{server_port}}
i        EOF		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i      # Install packages... redacted		{{server_addr}}	{{server_port}}
