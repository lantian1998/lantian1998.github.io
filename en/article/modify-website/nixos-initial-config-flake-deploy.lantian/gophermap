i    imports =		{{server_addr}}	{{server_port}}
i      [		{{server_addr}}	{{server_port}}
i        ./hardware-configuration.nix		{{server_addr}}	{{server_port}}
i      ];		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i    boot.loader.grub.enable = true;		{{server_addr}}	{{server_port}}
i    boot.loader.grub.version = 2;		{{server_addr}}	{{server_port}}
i    boot.loader.grub.device = "/dev/sda";		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
