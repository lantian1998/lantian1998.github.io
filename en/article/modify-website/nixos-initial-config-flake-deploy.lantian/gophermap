iThis file defines your whole NixOS operating system, including all		{{server_addr}}	{{server_port}}
isoftware packages and their config. This file is in Nix format, a "functional		{{server_addr}}	{{server_port}}
iprogramming" language created by NixOS's Nix package manager. But		{{server_addr}}	{{server_port}}
isince we're doing basic config, we don't need its programming		{{server_addr}}	{{server_port}}
ifunctionalities yet. Let's ignore the first line `{ config, pkgs, ... }:`		{{server_addr}}	{{server_port}}
ifor the moment and **treat the rest part as a JSON file** .		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iThe Nix language has the same 6 data types as JSON: number, boolean,		{{server_addr}}	{{server_port}}
istring, object, array, and null. Their format is also quite similar.		{{server_addr}}	{{server_port}}
iIn addition, the Nix language has a "path" data type:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  {		{{server_addr}}	{{server_port}}
i    # Number		{{server_addr}}	{{server_port}}
i    number = 123456;		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i    # Boolean		{{server_addr}}	{{server_port}}
i    boolean_value = true;		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i    # String		{{server_addr}}	{{server_port}}
i    string = "lantian.pub";		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i    # Object		{{server_addr}}	{{server_port}}
i    object = {		{{server_addr}}	{{server_port}}
i      a = 1;		{{server_addr}}	{{server_port}}
i      b = 2;		{{server_addr}}	{{server_port}}
i    };		{{server_addr}}	{{server_port}}
i    # The object can also be defined as this, they're equivalent:		{{server_addr}}	{{server_port}}
i    object.a = 1;		{{server_addr}}	{{server_port}}
i    object.b = 2;		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i    # Array		{{server_addr}}	{{server_port}}
i    array = [		{{server_addr}}	{{server_port}}
i      "first element"		{{server_addr}}	{{server_port}}
i      "second element"		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i      # Array can store objects:		{{server_addr}}	{{server_port}}
i      ({		{{server_addr}}	{{server_port}}
i        a = 1;		{{server_addr}}	{{server_port}}
i        b = 2;		{{server_addr}}	{{server_port}}
i      })		{{server_addr}}	{{server_port}}
i    ];		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i    # A Path, doesn't have double quotes like a string		{{server_addr}}	{{server_port}}
i    #		{{server_addr}}	{{server_port}}
i    # Note:		{{server_addr}}	{{server_port}}
i    #		{{server_addr}}	{{server_port}}
i    # - A file pointed by a path will be copied to /nix/store when parsing the config,		{{server_addr}}	{{server_port}}
i    #   and that copy will be used instead. A path usually points to a file managed		{{server_addr}}	{{server_port}}
i    #   along with this config, like your handwritten config file for some program.		{{server_addr}}	{{server_port}}
i    #		{{server_addr}}	{{server_port}}
i    # - A file pointed by a string won't be copied, but its contents aren't part of		{{server_addr}}	{{server_port}}
i    #   the config. They aren't managed by Nix and cannot be read by Nix, but the		{{server_addr}}	{{server_port}}
i    #   path itself can be copied to the program's config file and be read by the		{{server_addr}}	{{server_port}}
i    #   program. Usually, for files independent from the config, like the code of		{{server_addr}}	{{server_port}}
i    #   your website.		{{server_addr}}	{{server_port}}
i    file = ./somefile.txt;    # Will be copied to /nix/store/[hash]-somefile.txt		{{server_addr}}	{{server_port}}
i    file2 = "./somefile.txt"; # Won't be read or processed by Nix		{{server_addr}}	{{server_port}}
i  }		{{server_addr}}	{{server_port}}
