i## Enabling the Entire Address Pool		{{server_addr}}	{{server_port}}
iLinux kernel supports an AnyIP feature, allowing you to assign entire		{{server_addr}}	{{server_port}}
iaddress ranges to a network interface without manual configuration.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iAs an aside, a /64 address pool contains 18,446,744,073,709,551,616		{{server_addr}}	{{server_port}}
iIPs.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iEnable it with:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  ip -6 route add local [Your Assigned /64 Address Pool]/64 dev lo		{{server_addr}}	{{server_port}}
i  ip -6 route add local [Your Assigned /48 Address Pool - delete if unavailable]/48 dev lo		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iAfter execution, all IPs in your address pool become usable.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i## Using Native IPv6 and Tunnel Simultaneously		{{server_addr}}	{{server_port}}
iWhen multiple IPv6 connections coexist on a VPS, you'll find only one		{{server_addr}}	{{server_port}}
iworks at a time. Linux routes response packets through the default		{{server_addr}}	{{server_port}}
iinterface instead of the originating path.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iFortunately, Linux supports policy-based routing. Configure it as		{{server_addr}}	{{server_port}}
ifollows:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i- Create routing table and stop existing tunnel:		{{server_addr}}	{{server_port}}
i  echo 200 ipv6tb >> /etc/iproute2/rt_tables		{{server_addr}}	{{server_port}}
i  /etc/init.d/ipv6tb stop		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i- Replace the contents of `/etc/init.d/ipv6tb` with the following (modified		{{server_addr}}	{{server_port}}
i  from		{{server_addr}}	{{server_port}}
h  http://itkia.com/ipv6-policy-routing-linux-gotchas/	URL:http://itkia.com/ipv6-policy-routing-linux-gotchas/	{{server_addr}}	{{server_port}}
i  ):		{{server_addr}}	{{server_port}}
i  #! /bin/sh		{{server_addr}}	{{server_port}}
i  touch /var/lock/ipv6tb		{{server_addr}}	{{server_port}}
i  case "$1" in		{{server_addr}}	{{server_port}}
i      start)		{{server_addr}}	{{server_port}}
i          setsid /usr/bin/tb_userspace tb [HE Tunnel Server IPv4 Address] [Your VPS IPv4 Address] sit > /dev/null 2>&1 &		{{server_addr}}	{{server_port}}
i          sleep 1s		{{server_addr}}	{{server_port}}
i          # bring up the tunnel interface & set mtu		{{server_addr}}	{{server_port}}
i          ifconfig tb up		{{server_addr}}	{{server_port}}
i          ifconfig tb mtu 1480		{{server_addr}}	{{server_port}}
i          # hack: show ip in ifconfig		{{server_addr}}	{{server_port}}
i          ifconfig tb inet6 add [Your HE Tunnel Client IPv6 Address]/128		{{server_addr}}	{{server_port}}
i          ifconfig tb inet6 add [Your Assigned /64 Address Pool]::1/64		{{server_addr}}	{{server_port}}
i          ifconfig tb inet6 add [Your Assigned /48 Address Pool - delete if unavailable]::1/48		{{server_addr}}	{{server_port}}
i          # make use of the whole ipv6 block		{{server_addr}}	{{server_port}}
i          ip -6 route add local [Your VPS Native IPv6 Address]/128 dev lo		{{server_addr}}	{{server_port}}
i          ip -6 route add local [Your HE Tunnel Client IPv6 Address]/128 dev lo		{{server_addr}}	{{server_port}}
i          ip -6 route add local [Your Assigned /64 Address Pool]/64 dev lo		{{server_addr}}	{{server_port}}
i          ip -6 route add local [Your Assigned /48 Address Pool - delete if unavailable]/48 dev lo		{{server_addr}}	{{server_port}}
i          # nullroute native ipv6 to prevent sending via wrong interface		{{server_addr}}	{{server_port}}
i          ip -6 route add unreachable [Your VPS Native IPv6 Address]/128		{{server_addr}}	{{server_port}}
i          # nullroute ipv6 tunnel to prevent sending via wrong interface		{{server_addr}}	{{server_port}}
i          ip -6 route add unreachable [Your HE Tunnel Client IPv6 Address]/128		{{server_addr}}	{{server_port}}
i          ip -6 route add unreachable [Your Assigned /64 Address Pool]/64		{{server_addr}}	{{server_port}}
i          ip -6 route add unreachable [Your Assigned /48 Address Pool - delete if unavailable]/48		{{server_addr}}	{{server_port}}
i          # flush route table & route the interfaces		{{server_addr}}	{{server_port}}
i          ip -6 route flush table ipv6tb		{{server_addr}}	{{server_port}}
i          ip -6 route add 2000::/3 dev venet0 src [Your VPS Native IPv6 Address]		{{server_addr}}	{{server_port}}
i          ip -6 route add 2000::/3 dev tb src [Your HE Tunnel Client IPv6 Address] table ipv6tb		{{server_addr}}	{{server_port}}
i          # flush rule table		{{server_addr}}	{{server_port}}
i          ip -6 rule flush		{{server_addr}}	{{server_port}}
i          # restore routing in ipv6 tunnel address block		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 200 to [Your HE Tunnel Client IPv6 Address]/128 table main		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 201 to [Your Assigned /64 Address Pool]/64 table main		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 202 to [Your Assigned /48 Address Pool - delete if unavailable]/48 table main		{{server_addr}}	{{server_port}}
i          # restore routing in native ipv6 address block		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 210 to [Your VPS Native IPv6 Address]/128 table main		{{server_addr}}	{{server_port}}
i          # restore routing to reserved ipv6 range		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 1000 to 2001:db8::/32 table main		{{server_addr}}	{{server_port}}
i          # route packets from tunnel back to the tunnel		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 30000 from [Your HE Tunnel Client IPv6 Address]/128 to 2000::/3 table ipv6tb		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 30001 from [Your Assigned /64 Address Pool]/64 to 2000::/3 table ipv6tb		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 30002 from [Your Assigned /48 Address Pool - delete if unavailable]/48 to 2000::/3 table ipv6tb		{{server_addr}}	{{server_port}}
i          # restore ipv6 main route & flush cache		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 32766 from all table main		{{server_addr}}	{{server_port}}
i          ip -6 route flush cache		{{server_addr}}	{{server_port}}
i      ;;		{{server_addr}}	{{server_port}}
i      stop)		{{server_addr}}	{{server_port}}
i          ifconfig tb down		{{server_addr}}	{{server_port}}
i          # restore rule table		{{server_addr}}	{{server_port}}
i          ip -6 rule flush		{{server_addr}}	{{server_port}}
i          ip -6 rule add priority 32766 from all table main		{{server_addr}}	{{server_port}}
i          pkill -9 tb_userspace		{{server_addr}}	{{server_port}}
i      ;;		{{server_addr}}	{{server_port}}
i      *)		{{server_addr}}	{{server_port}}
i          echo "Usage: /etc/init.d/ipv6tb {start|stop}"		{{server_addr}}	{{server_port}}
i          exit 1		{{server_addr}}	{{server_port}}
i          ;;		{{server_addr}}	{{server_port}}
i  esac		{{server_addr}}	{{server_port}}
i  exit 0		{{server_addr}}	{{server_port}}
