i## (Optional) Regenerate Diameter TLS Certificates		{{server_addr}}	{{server_port}}
iOpen5GS packaged in Nixpkgs comes with a TLS certificate generated		{{server_addr}}	{{server_port}}
iduring the build process. If your Open5GS is downloaded from the		{{server_addr}}	{{server_port}}
iBinary Cache instead of being compiled locally, you will be using the		{{server_addr}}	{{server_port}}
isame TLS key others can download from the Binary Cache.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iIf you deploy on a single machine according to this tutorial, since		{{server_addr}}	{{server_port}}
iall communication is local and does not go through external networks,		{{server_addr}}	{{server_port}}
iencryption and private key leakage have little impact on security.		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iHowever, if you plan to place some components on other machines, or if		{{server_addr}}	{{server_port}}
iyou do not want to use this leaked key, you can generate a new one		{{server_addr}}	{{server_port}}
iusing the following script:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  {		{{server_addr}}	{{server_port}}
i    pkgs,		{{server_addr}}	{{server_port}}
i    ...		{{server_addr}}	{{server_port}}
i  }:		{{server_addr}}	{{server_port}}
i  {		{{server_addr}}	{{server_port}}
i    systemd.services.open5gs-certs = {		{{server_addr}}	{{server_port}}
i      wantedBy = [ "multi-user.target" ];		{{server_addr}}	{{server_port}}
i      path = with pkgs; [ openssl ];		{{server_addr}}	{{server_port}}
i      script = ''		{{server_addr}}	{{server_port}}
i        mkdir -p demoCA		{{server_addr}}	{{server_port}}
i        if [ ! -f "demoCA/serial" ]; then		{{server_addr}}	{{server_port}}
i          echo 01 > demoCA/serial		{{server_addr}}	{{server_port}}
i        fi		{{server_addr}}	{{server_port}}
i        touch demoCA/index.txt		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i        # CA self certificate		{{server_addr}}	{{server_port}}
i        if [ ! -f "ca.crt" ]; then		{{server_addr}}	{{server_port}}
i          openssl req -new -x509 -days 3650 -newkey rsa:2048 -nodes -keyout ca.key -out ca.crt \		{{server_addr}}	{{server_port}}
i            -subj /CN=ca.epc.mnc010.mcc315.3gppnetwork.org/C=KO/ST=Seoul/O=NeoPlane		{{server_addr}}	{{server_port}}
i        fi		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i        for i in amf ausf bsf hss mme nrf scp sepp1 sepp2 sepp3 nssf pcf pcrf smf udm udr		{{server_addr}}	{{server_port}}
i        do		{{server_addr}}	{{server_port}}
i          if [ ! -f "$i.crt" ]; then		{{server_addr}}	{{server_port}}
i            openssl genpkey -algorithm rsa -pkeyopt rsa_keygen_bits:2048 \		{{server_addr}}	{{server_port}}
i                -out $i.key		{{server_addr}}	{{server_port}}
i            openssl req -new -key $i.key -out $i.csr \		{{server_addr}}	{{server_port}}
i                -subj /CN=$i.epc.mnc010.mcc315.3gppnetwork.org/C=KO/ST=Seoul/O=NeoPlane		{{server_addr}}	{{server_port}}
i            openssl ca -batch -notext -days 3650 \		{{server_addr}}	{{server_port}}
i                -keyfile ca.key -cert ca.crt \		{{server_addr}}	{{server_port}}
i                -in $i.csr -out $i.crt -outdir .		{{server_addr}}	{{server_port}}
i          fi		{{server_addr}}	{{server_port}}
i        done		{{server_addr}}	{{server_port}}
i      '';		{{server_addr}}	{{server_port}}
i      serviceConfig = {		{{server_addr}}	{{server_port}}
i        Type = "oneshot";		{{server_addr}}	{{server_port}}
i        User = "open5gs";		{{server_addr}}	{{server_port}}
i        Group = "open5gs";		{{server_addr}}	{{server_port}}
i        StateDirectory = "open5gs-certs";		{{server_addr}}	{{server_port}}
i        WorkingDirectory = "/var/lib/open5gs-certs";		{{server_addr}}	{{server_port}}
i      };		{{server_addr}}	{{server_port}}
i    };		{{server_addr}}	{{server_port}}
i  }		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iWhen you run `systemctl start open5gs-certs.service` , this service		{{server_addr}}	{{server_port}}
iwill automatically generate missing keys in `/var/lib/open5gs-certs` .		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
iThen you can modify the Open5GS configuration file to point the TLS		{{server_addr}}	{{server_port}}
ikey path to `/var/lib/open5gs-certs` :		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  # If you did not replace the TLS key path in the previous step		{{server_addr}}	{{server_port}}
i  sed -i "s#/nix/store/vbb0aa2mkjbfay7gdgaw5r23g0ss6kyz-open5gs-v2.7.6/etc/open5gs/tls/#/var/lib/open5gs-certs/#g" freeDiameter/* open5gs/*		{{server_addr}}	{{server_port}}
