i        "network.target"		{{server_addr}}	{{server_port}}
i        "open5gs-certs.service"		{{server_addr}}	{{server_port}}
i        "mongodb.service"		{{server_addr}}	{{server_port}}
i      ];		{{server_addr}}	{{server_port}}
i      # ...		{{server_addr}}	{{server_port}}
i    };		{{server_addr}}	{{server_port}}
i  }		{{server_addr}}	{{server_port}}
