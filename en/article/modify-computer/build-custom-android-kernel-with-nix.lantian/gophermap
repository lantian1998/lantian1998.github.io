i  [kernelsu-stable-revision-code]		{{server_addr}}	{{server_port}}
i  src.manual = "11872"		{{server_addr}}	{{server_port}}
i  # Download URL doesn't matter, we only need the version code		{{server_addr}}	{{server_port}}
i  fetch.url = "https://example.com"		{{server_addr}}	{{server_port}}
