i       <hyperv mode="custom">		{{server_addr}}	{{server_port}}
i         <relaxed state="on"/>		{{server_addr}}	{{server_port}}
i         <vapic state="on"/>		{{server_addr}}	{{server_port}}
i         <spinlocks state="on" retries="8191"/>		{{server_addr}}	{{server_port}}
i         <vpindex state="on"/>		{{server_addr}}	{{server_port}}
i         <runtime state="on"/>		{{server_addr}}	{{server_port}}
i         <synic state="on"/>		{{server_addr}}	{{server_port}}
i         <stimer state="on"/>		{{server_addr}}	{{server_port}}
i         <reset state="on"/>		{{server_addr}}	{{server_port}}
i         <vendor_id state="on" value="GenuineIntel"/>		{{server_addr}}	{{server_port}}
i         <frequencies state="on"/>		{{server_addr}}	{{server_port}}
i         <tlbflush state="on"/>		{{server_addr}}	{{server_port}}
i       </hyperv>		{{server_addr}}	{{server_port}}
i       <kvm>		{{server_addr}}	{{server_port}}
i         <hidden state="on"/>		{{server_addr}}	{{server_port}}
i       </kvm>		{{server_addr}}	{{server_port}}
i       <vmport state="off"/>		{{server_addr}}	{{server_port}}
i     </features>		{{server_addr}}	{{server_port}}
i     <!-- Add the PCIe passthrough device, must be below the hostdev for iGPU -->		{{server_addr}}	{{server_port}}
i     <hostdev mode='subsystem' type='pci' managed='yes'>		{{server_addr}}	{{server_port}}
i       <source>		{{server_addr}}	{{server_port}}
i         <address domain='0x0000' bus='0x01' slot='0x00' function='0x0'/>		{{server_addr}}	{{server_port}}
i       </source>		{{server_addr}}	{{server_port}}
i       <rom bar='off'/>		{{server_addr}}	{{server_port}}
i       <!-- The PCIe bus address here MUST BE EXACTLY 01:00.0 -->		{{server_addr}}	{{server_port}}
i       <!-- If there is a PCIe bus address conflict when saving config changes, -->		{{server_addr}}	{{server_port}}
i       <!-- Remove <address> of all other devices -->		{{server_addr}}	{{server_port}}
i       <!-- And Libvirt will reallocate PCIe bus addresses -->		{{server_addr}}	{{server_port}}
i       <address type='pci' domain='0x0000' bus='0x01' slot='0x00' function='0x0' multifunction='on'/>		{{server_addr}}	{{server_port}}
i     </hostdev>		{{server_addr}}	{{server_port}}
