i  		{{server_addr}}	{{server_port}}
i    # Modulos function, "a mod b". Used for limiting input to sin/cos to (-2pi, 2pi)		{{server_addr}}	{{server_port}}
i    mod = a: b:		{{server_addr}}	{{server_port}}
i      if a < 0		{{server_addr}}	{{server_port}}
