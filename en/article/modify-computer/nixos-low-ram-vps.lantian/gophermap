iThen, we need to set up partitioning in the disk image with options		{{server_addr}}	{{server_port}}
iprovided by Disko. Modify `configuration.nix` and add the following		{{server_addr}}	{{server_port}}
iconfig:		{{server_addr}}	{{server_port}}
i		{{server_addr}}	{{server_port}}
i  {		{{server_addr}}	{{server_port}}
i    config,		{{server_addr}}	{{server_port}}
i    pkgs,		{{server_addr}}	{{server_port}}
i    lib,		{{server_addr}}	{{server_port}}
i    ...		{{server_addr}}	{{server_port}}
i  }: {		{{server_addr}}	{{server_port}}
i    # Other configurations omitted		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i    disko = {		{{server_addr}}	{{server_port}}
i      # Do not let Disko manage fileSystems.* config for NixOS.		{{server_addr}}	{{server_port}}
i      # Reason is that Disko mounts partitions by GPT partition names, which are		{{server_addr}}	{{server_port}}
i      # easily overwritten with tools like fdisk. When you fail to deploy a new		{{server_addr}}	{{server_port}}
i      # config in this case, the old config that comes with the disk image will		{{server_addr}}	{{server_port}}
i      # not boot either.		{{server_addr}}	{{server_port}}
i      enableConfig = false;		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i      devices = {		{{server_addr}}	{{server_port}}
i        # Define a disk		{{server_addr}}	{{server_port}}
i        disk.main = {		{{server_addr}}	{{server_port}}
i          # Size for generated disk image. 2GB is enough for me. Adjust per your need.		{{server_addr}}	{{server_port}}
i          imageSize = "2G";		{{server_addr}}	{{server_port}}
i          # Path to disk. When Disko generates disk images, it actually runs a QEMU		{{server_addr}}	{{server_port}}
i          # virtual machine and runs the installation steps. Whether your VPS		{{server_addr}}	{{server_port}}
i          # recognizes its hard disk as "sda" or "vda" doesn't matter. We abide to		{{server_addr}}	{{server_port}}
i          # Disko's QEMU VM and use "vda" here.		{{server_addr}}	{{server_port}}
i          device = "/dev/vda";		{{server_addr}}	{{server_port}}
i          type = "disk";		{{server_addr}}	{{server_port}}
i          # Parititon table for this disk		{{server_addr}}	{{server_port}}
i          content = {		{{server_addr}}	{{server_port}}
i            # Use GPT partition table. There seems to be some issues with MBR support		{{server_addr}}	{{server_port}}
i            # from Disko.		{{server_addr}}	{{server_port}}
i            type = "gpt";		{{server_addr}}	{{server_port}}
i            # Partition list		{{server_addr}}	{{server_port}}
i            partitions = {		{{server_addr}}	{{server_port}}
i              # Compared to MBR, GPT partition table doesn't reserve space for MBR		{{server_addr}}	{{server_port}}
i              # boot record. We need to reserve the first 1MB for MBR boot record,		{{server_addr}}	{{server_port}}
i              # so Grub can be installed here.		{{server_addr}}	{{server_port}}
i              boot = {		{{server_addr}}	{{server_port}}
i                size = "1M";		{{server_addr}}	{{server_port}}
i                type = "EF02"; # for grub MBR		{{server_addr}}	{{server_port}}
i                # Use the highest priority to ensure it's at the beginning		{{server_addr}}	{{server_port}}
i                priority = 0;		{{server_addr}}	{{server_port}}
i              };		{{server_addr}}	{{server_port}}
i  		{{server_addr}}	{{server_port}}
i              # ESP partition, or "boot" partition as you may call it. In theory,		{{server_addr}}	{{server_port}}
i              # this config will support VPSes with both EFI and BIOS boot modes.		{{server_addr}}	{{server_port}}
i              ESP = {		{{server_addr}}	{{server_port}}
